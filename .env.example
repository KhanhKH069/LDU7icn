# ============================================================
# LDU7icn — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- General ---
APP_ENV=development
LOG_LEVEL=INFO
PROJECT_NAME=LDU7icn

# --- Whisper ---
WHISPER_MODEL=base          # tiny | base | small | medium | large
WHISPER_LANGUAGE=vi         # vi | en | auto
WHISPER_DEVICE=cpu          # cpu | cuda
AUDIO_SAMPLE_RATE=16000
AUDIO_CHUNK_DURATION=3      # seconds

# --- YOLO ---
YOLO_MODEL_PATH=models/yolo/yolov8n.pt
YOLO_CONFIDENCE=0.5
YOLO_IOU_THRESHOLD=0.45
YOLO_DEVICE=cpu             # cpu | cuda | 0 | 1
CAMERA_INDEX=0
FRAME_WIDTH=640
FRAME_HEIGHT=480
TARGET_FPS=30

# --- Flight Controller ---
MAVLINK_CONNECTION=udp:127.0.0.1:14550   # SITL
# MAVLINK_CONNECTION=serial:/dev/ttyUSB0:57600  # Real hardware
MAVLINK_SYSTEM_ID=1
TAKEOFF_ALTITUDE=5          # meters
MAX_SPEED=5                 # m/s
GEOFENCE_RADIUS=100         # meters

# --- API Server ---
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
JWT_SECRET=change_me_in_production
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- MQTT ---
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_KEEPALIVE=60
MQTT_TOPIC_COMMAND=uav/command
MQTT_TOPIC_TELEMETRY=uav/telemetry
MQTT_TOPIC_DETECTION=uav/detection

# --- OpenAI (optional fallback) ---
OPENAI_API_KEY=sk-...
